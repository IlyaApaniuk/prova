# --- Database (Prisma) ---
# LOCAL DEV: `docker compose up -d` starts Postgres on 5434
# (5432/5433 are taken by other projects on this machine), then:
#   npx prisma migrate deploy && npx prisma db seed
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5434/prova"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5434/prova"
#
# CLOUD (Supabase → Project settings → Database → Connection string):
# DATABASE_URL uses the pooled (pgBouncer) port 6543; DIRECT_URL uses 5432 for migrations.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase (auth/storage; not needed for local DB-only work) ---
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# --- PostHog (analytics / funnels) ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Stripe (behind a feature flag, off for now) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# --- Resend (transactional email) ---
# RESEND_API_KEY=""
