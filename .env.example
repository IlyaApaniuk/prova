# --- Database (Prisma) ---
# LOCAL DEV: `supabase start` runs the trimmed local stack (supabase/config.toml),
# then: npx prisma migrate deploy && npx prisma db seed
# Ports 55321-55324 (API/db/studio/mailpit); 54xxx belongs to another project.
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:55322/postgres"
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:55322/postgres"
#
# CLOUD (Supabase → Project settings → Database → Connection string):
# DATABASE_URL uses the pooled (pgBouncer) port 6543; DIRECT_URL uses 5432 for migrations.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase auth ---
# LOCAL DEV: URL is http://127.0.0.1:55321, key is the "Publishable" value
# printed by `supabase status`.
# CLOUD: Project settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-KEY"

# --- Google OAuth (local sign-in with Google; see supabase/config.toml) ---
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=""
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=""

# --- PostHog (analytics / funnels) ---
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Stripe (behind a feature flag, off for now) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# --- Resend (transactional email) ---
# RESEND_API_KEY=""
